# Claude API (用于翻译和摘要生成)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# 邮件配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your_qq_email@qq.com
SMTP_PASSWORD=your_qq_authorization_code
EMAIL_FROM=your_qq_email@qq.com
EMAIL_TO=recipient_email@qq.com

# 脚本配置
LOG_LEVEL=INFO
TIME_WINDOW_HOURS=24
MAX_ITEMS_TO_SEND=15
USE_LLM_TRANSLATION=true
DATABASE_PATH=data/sent_records.db
OUTPUT_PATH=output/latest_report.html
