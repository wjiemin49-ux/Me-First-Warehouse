{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://script-console.local/schemas/script-console.manifest.schema.json",
  "title": "Script Console Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description",
    "version",
    "author",
    "type",
    "entry",
    "stop",
    "logging",
    "health",
    "display",
    "policy"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-_]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "type": {
      "enum": ["python", "node", "powershell", "bat", "exe", "java", "go", "rust", "unknown"]
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "args", "cwd", "shell"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } },
        "cwd": { "type": "string", "minLength": 1 },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "shell": { "type": "boolean" }
      }
    },
    "stop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["process", "command", "http", "none"] },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "command": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command", "args"],
          "properties": {
            "command": { "type": "string", "minLength": 1 },
            "args": { "type": "array", "items": { "type": "string" } },
            "cwd": { "type": "string" }
          }
        },
        "http": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url"],
          "properties": {
            "url": { "type": "string", "minLength": 1 },
            "method": { "enum": ["GET", "POST"] },
            "timeoutMs": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filePath": { "type": "string" },
        "maxTailLines": { "type": "integer", "minimum": 1 },
        "levelPattern": { "type": "string" },
        "captureStdout": { "type": "boolean" },
        "captureStderr": { "type": "boolean" }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["probes"],
      "properties": {
        "graceSeconds": { "type": "integer", "minimum": 0 },
        "probes": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "severity"],
                "properties": {
                  "type": { "const": "process" },
                  "severity": { "enum": ["required", "advisory"] },
                  "timeoutMs": { "type": "integer", "minimum": 1 }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "severity", "path"],
                "properties": {
                  "type": { "const": "heartbeat-file" },
                  "severity": { "enum": ["required", "advisory"] },
                  "path": { "type": "string", "minLength": 1 },
                  "staleAfterSeconds": { "type": "integer", "minimum": 1 },
                  "timeoutMs": { "type": "integer", "minimum": 1 }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "severity", "url"],
                "properties": {
                  "type": { "const": "http" },
                  "severity": { "enum": ["required", "advisory"] },
                  "url": { "type": "string", "minLength": 1 },
                  "expectedStatus": { "type": "integer", "minimum": 1 },
                  "timeoutMs": { "type": "integer", "minimum": 1 }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "severity", "port"],
                "properties": {
                  "type": { "const": "port" },
                  "severity": { "enum": ["required", "advisory"] },
                  "port": { "type": "integer", "minimum": 1 },
                  "host": { "type": "string" },
                  "timeoutMs": { "type": "integer", "minimum": 1 }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "severity"],
                "properties": {
                  "type": { "const": "log-update" },
                  "severity": { "enum": ["required", "advisory"] },
                  "path": { "type": "string" },
                  "staleAfterSeconds": { "type": "integer", "minimum": 1 },
                  "timeoutMs": { "type": "integer", "minimum": 1 }
                }
              }
            ]
          }
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "tags"],
      "properties": {
        "category": { "type": "string", "minLength": 1 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "icon": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowAutoStart", "allowVisible"],
      "properties": {
        "allowAutoStart": { "type": "boolean" },
        "allowVisible": { "type": "boolean" },
        "restartPolicy": { "enum": ["off", "on-crash", "on-crash-or-unresponsive"] },
        "restartMaxRetries": { "type": "integer", "minimum": 0 },
        "cooldownMinutes": { "type": "integer", "minimum": 1 }
      }
    },
    "processMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executableName": { "type": "string" },
        "commandLineIncludes": { "type": "string" }
      },
      "anyOf": [
        { "required": ["executableName"] },
        { "required": ["commandLineIncludes"] }
      ]
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
